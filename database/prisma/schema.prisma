datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id           String    @id @db.Uuid
  name         String
  email        String    @unique
  role         String    @default("member")
  department   String?
  enrollment   String?
  institute    String?
  mobile       String?
  avatar_url   String?
  approved     Boolean   @default(false)
  badge_url    String?
  password_set Boolean   @default(true)
  created_at   DateTime  @default(now())

  // Relations
  eventsCreated Event[]  @relation("CreatedEvents")
  teamProfile   TeamMember? @relation("TeamProfile")
  teamApproved  TeamMember[] @relation("ApprovedTeam")
  certifications Certification[]
}

model Event {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  type        String
  date        String
  time        String?
  location    String?
  description String?
  status      String   @default("upcoming")
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now())

  // Relations
  creator     Profile? @relation("CreatedEvents", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([created_by])
}

model TeamMember {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String    @unique @db.Uuid
  role_title  String?
  department  String?
  linkedin    String?
  github      String?
  approved_by String?   @db.Uuid
  approved_at DateTime?
  created_at  DateTime  @default(now())

  // Relations
  profile     Profile   @relation("TeamProfile", fields: [profile_id], references: [id], onDelete: Cascade)
  approver    Profile?  @relation("ApprovedTeam", fields: [approved_by], references: [id], onDelete: SetNull)

  @@index([approved_by])
}

model Certification {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id   String?  @db.Uuid
  name         String
  email        String
  parul_email  String?
  mobile              String?
  enrollment          String?
  department          String?
  semester            String?
  institute           String?
  exam_date           String?
  certificate_title   String
  credly_link         String?
  result_url   String?
  photo_url    String?
  post_draft   String?
  status       String   @default("pending")
  created_at   DateTime @default(now())

  // Relations
  profile      Profile? @relation(fields: [profile_id], references: [id], onDelete: SetNull)

  @@index([profile_id])
  @@index([status])
  @@index([email])
}

model Setting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String   @unique
  value      Json
  updated_at DateTime @default(now())
  updated_by String?  @db.Uuid
}
